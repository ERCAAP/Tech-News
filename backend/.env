# AWS Configuration
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB Tables
DYNAMODB_USERS_TABLE=TechNews-Users-Prod
DYNAMODB_NEWS_TABLE=TechNews-News-Prod

# S3 Configuration
S3_UPLOADS_BUCKET=tech-news-uploads-prod

# Cognito Configuration
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CloudFront
CLOUDFRONT_DISTRIBUTION_URL=https://dxxxxxxxx.cloudfront.net

# API Gateway
API_GATEWAY_ID=xxxxxxxxxx
API_GATEWAY_ENDPOINT=https://xxxxxxxxxx.execute-api.eu-central-1.amazonaws.com/prod

# Server Configuration
PORT=3000
NODE_ENV=production

# Email Configuration (SES)
SES_FROM_EMAIL=noreply@your-domain.com
SES_REGION=eu-central-1

# SNS Configuration
SNS_TOPIC_ARN=arn:aws:sns:eu-central-1:xxxxxxxxxxxx:tech-news-notifications

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://search-tech-news-xxxxxxxxxxxxxx.eu-central-1.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your-secure-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/tech-news/api
CLOUDWATCH_LOG_STREAM=production

# Push Notifications
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_API_KEY=your-api-key

